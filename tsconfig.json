{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "rootDir": "./",
    "strict": true,

    "esModuleInterop": true,
    "resolveJsonModule": true,

    "types": ["node", "jest"],

    "skipLibCheck": true
  },

  "include": [
    "src/**/*.ts",
    "tests/**/*.ts"
  ]
}